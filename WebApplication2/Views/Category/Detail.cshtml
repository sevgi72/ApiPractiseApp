@using WebApplication2.ViewModels
@model CategoryReturnDto

@{
	ViewData["Title"] = "Kategori Detayı";
}

<div class="container-fluid py-5">
	<div class="row mb-5">
		<div class="col-lg-8">
			<h1 class="display-5 fw-bold mb-2">Kategori Detayı</h1>
			<p class="lead text-muted">Kategori bilgilerini görüntüleyin</p>
		</div>
		<div class="col-lg-4 d-flex align-items-center justify-content-end gap-2">
			<a asp-action="Index" class="btn btn-secondary btn-lg">
				<i class="ti ti-arrow-left me-2"></i>Geri Dön
			</a>
		</div>
	</div>

	<div class="card shadow-sm border-0">
		<div class="card-body">
			<h5 class="card-title fw-bold">@Model.Name</h5>
			<p class="card-text">@Model.Description</p>
			<div class="text-muted small">
				<span>
					<i class="ti ti-hash me-1"></i>ID: @Model.Id
				</span>
			</div>
		</div>
	</div>
</div>
