@using WebApplication2.ViewModels
@model List<CategoryReturnDto>

@{
    ViewData["Title"] = "Kategoriler";
}

<div class="container-fluid py-5">
    <!-- Header Section -->
    <div class="row mb-5">
        <div class="col-lg-8">
            <div>
                <h1 class="display-5 fw-bold mb-2">Kategoriler</h1>
                <p class="lead text-muted">Tüm ürün kategorilerini yönetin</p>
            </div>
        </div>
        <div class="col-lg-4 d-flex align-items-center justify-content-end gap-2">
            <a href="#" class="btn btn-primary btn-lg">
                <i class="ti ti-plus me-2"></i>Yeni Kategori
            </a>
        </div>
    </div>

    <!-- Error Message Alert -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <div class="d-flex align-items-start gap-3">
                <i class="ti ti-alert-circle text-danger fs-4"></i>
                <div>
                    <strong>Hata Oluştu</strong>
                    <p class="mb-0">@TempData["ErrorMessage"]</p>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <!-- Success Message Alert (optional) -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <div class="d-flex align-items-start gap-3">
                <i class="ti ti-check-circle text-success fs-4"></i>
                <div>
                    <strong>Başarılı</strong>
                    <p class="mb-0">@TempData["SuccessMessage"]</p>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <!-- Categories Grid -->
    @if (Model != null && Model.Count > 0)
    {
        <div class="row g-4">
            @foreach (var category in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card category-card h-100 shadow-sm border-0 overflow-hidden">
                        <!-- Card Image Placeholder -->
                        <div class="category-image-wrapper position-relative bg-light" style="height: 200px;">
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-gradient">
                                <i class="ti ti-folder-open text-muted" style="font-size: 48px;"></i>
                            </div>
                            <div class="category-badge position-absolute top-0 end-0 m-3">
                                <span class="badge bg-primary">Aktif</span>
                            </div>
                        </div>

                        <!-- Card Body -->
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold mb-2 text-truncate">
                                @category.Name
                            </h5>

                            @if (!string.IsNullOrEmpty(category.Description))
                            {
                                <p class="card-text text-muted small mb-3 flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    @category.Description
                                </p>
                            }
                            else
                            {
                                <p class="card-text text-muted small mb-3 flex-grow-1">
                                    <em>Açıklama yok</em>
                                </p>
                            }

                            <!-- Meta Info -->
                            <div class="d-flex gap-2 mb-3 text-muted small border-top pt-3">
                                <span>
                                    <i class="ti ti-hash me-1"></i>ID: @category.Id
                                </span>
                            </div>

                            <!-- Card Actions -->
                            <div class="btn-group w-100" role="group">
                                <a href="#" class="btn btn-sm btn-outline-primary" title="Düzenle">
                                    <i class="ti ti-edit me-1"></i>Düzenle
                                </a>
                                <a href="#" class="btn btn-sm btn-outline-danger" title="Sil" onclick="return confirm('Bu kategoriyi silmek istediğinizden emin misiniz?')">
                                    <i class="ti ti-trash me-1"></i>Sil
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Categories Count Summary -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="bg-light p-4 rounded-3 border">
                    <div class="d-flex align-items-center gap-3">
                        <i class="ti ti-layout-list text-primary" style="font-size: 28px;"></i>
                        <div>
                            <h6 class="mb-0 text-muted">Toplam Kategoriler</h6>
                            <h3 class="mb-0 fw-bold">@Model.Count</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="row">
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body py-5 text-center">
                        <div class="mb-4">
                            <i class="ti ti-inbox" style="font-size: 64px; color: #ccc;"></i>
                        </div>
                        <h4 class="mb-2 fw-bold">Kategori Bulunamadı</h4>
                        <p class="text-muted mb-4">Henüz hiç kategori oluşturulmamış. Yeni bir kategori eklemek için aşağıdaki butona tıklayın.</p>
                        <a href="#" class="btn btn-primary btn-lg">
                            <i class="ti ti-plus me-2"></i>İlk Kategoriyi Oluştur
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

