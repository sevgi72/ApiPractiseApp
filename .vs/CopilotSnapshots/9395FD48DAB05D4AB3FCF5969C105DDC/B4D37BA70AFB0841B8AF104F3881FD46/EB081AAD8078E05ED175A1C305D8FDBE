@using WebApplication2.ViewModels
@model List<ProductVm>

@{
    ViewData["Title"] = "Ürünler";
}

<div class="container-fluid py-5">
    <!-- Header Section -->
    <div class="row mb-5">
        <div class="col-lg-8">
            <div>
                <h1 class="display-5 fw-bold mb-2">Ürünler</h1>
                <p class="lead text-muted">Tüm ürünleri yönetin</p>
            </div>
        </div>
        <div class="col-lg-4 d-flex align-items-center justify-content-end gap-2">
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="ti ti-plus me-2"></i>Yeni Ürün
            </a>
        </div>
    </div>

    <!-- Error Message Alert -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <div class="d-flex align-items-start gap-3">
                <i class="ti ti-alert-circle text-danger fs-4"></i>
                <div>
                    <strong>Hata Oluştu</strong>
                    <p class="mb-0">@TempData["ErrorMessage"]</p>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
        </div>
    }

    <!-- Products Grid -->
    @if (Model != null && Model.Count > 0)
    {
        <div class="row g-4">
            @foreach (var product in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <span class="badge bg-info text-dark">@product.Category?.Name</span>
                            <span class="fw-bold text-success">@product.Price.ToString("C")</span>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title fw-bold text-truncate" title="@product.Name">@product.Name</h5>
                            <p class="card-text text-muted small" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @(string.IsNullOrEmpty(product.Description) ? "Açıklama yok" : product.Description)
                            </p>

                            @if (product.ProductColors != null && product.ProductColors.Any())
                            {
                                <div class="mt-3">
                                    <small class="text-muted d-block mb-1">Renkler:</small>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var color in product.ProductColors)
                                        {
                                            <span class="badge bg-secondary">@color.ColorName</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-white border-top-0 d-flex justify-content-between">
                            <div class="btn-group w-100">
                                <a href="#" class="btn btn-sm btn-outline-info">
                                    <i class="ti ti-eye me-1"></i>Detay
                                </a>
                                <a href="#" class="btn btn-sm btn-outline-primary">
                                    <i class="ti ti-edit me-1"></i>Düzenle
                                </a>
                                <a href="#" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                    <i class="ti ti-trash me-1"></i>Sil
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm col-12 text-center py-5">
            <h4 class="fw-bold">Ürün Bulunamadı</h4>
            <p class="text-muted">Kayıtlı hiçbir ürün yok.</p>
        </div>
    }
</div>
