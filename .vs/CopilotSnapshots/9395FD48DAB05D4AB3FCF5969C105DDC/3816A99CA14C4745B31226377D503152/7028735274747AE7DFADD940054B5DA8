using Microsoft.AspNetCore.Mvc;
using System.Text.Json;
using WebApplication2.ViewModels;
using WebApplication2.Filters;

namespace WebApplication2.Controllers
{
    [TokenAuthFilter]
    public class ProductController : Controller
    {
        private readonly IHttpClientFactory _httpClientFactory;

        public ProductController(IHttpClientFactory httpClientFactory)
        {
            _httpClientFactory = httpClientFactory;
        }

        public async Task<IActionResult> Index()
        {
            try
            {
                var httpClient = _httpClientFactory.CreateClient("ApiClient");

                var response = await httpClient.GetAsync("http://localhost:5202/api/Product");

                if (response.IsSuccessStatusCode)
                {
                    var responseContent = await response.Content.ReadAsStringAsync();

                    var products = JsonSerializer.Deserialize<List<ProductVm>>(
                        responseContent,
                        new JsonSerializerOptions
                        {
                            PropertyNameCaseInsensitive = true
                        });

                    return View(products ?? new List<ProductVm>());
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    TempData["ErrorMessage"] = $"Failed to retrieve products. Status: {response.StatusCode}, Details: {errorContent}";
                    return View(new List<ProductVm>());
                }
            }
            catch (Exception ex)
            {
                TempData["ErrorMessage"] = $"An error occurred: {ex.Message}";
                return View(new List<ProductVm>());
            }
        }

        [HttpGet]
        public async Task<IActionResult> Create()
        {
            try
            {
                var httpClient = _httpClientFactory.CreateClient("ApiClient");

                // Fetch colors
                var colorResponse = await httpClient.GetAsync("http://localhost:5202/api/color");
                if (colorResponse.IsSuccessStatusCode)
                {
                    var colorContent = await colorResponse.Content.ReadAsStringAsync();
                    var colors = JsonSerializer.Deserialize<List<ColorVm>>(colorContent, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    ViewBag.Colors = colors;
                }
                else
                {
                    ViewBag.Colors = new List<ColorVm>();
                    TempData["ErrorMessage"] = "Could not load colors.";
                }

                // Assuming we also need categories for the dropdown, fetching them:
                var categoryResponse = await httpClient.GetAsync("http://localhost:5202/api/category");
                if (categoryResponse.IsSuccessStatusCode)
                {
                    var categoryContent = await categoryResponse.Content.ReadAsStringAsync();
                    var categories = JsonSerializer.Deserialize<List<CategoryReturnDto>>(categoryContent, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    ViewBag.Categories = categories;
                }
                else
                {
                    ViewBag.Categories = new List<CategoryReturnDto>();
                    TempData["ErrorMessage"] = "Could not load categories.";
                }
            }
            catch (Exception ex)
            {
                TempData["ErrorMessage"] = $"An error occurred while loading form data: {ex.Message}";
                ViewBag.Colors = new List<ColorVm>();
                ViewBag.Categories = new List<CategoryReturnDto>();
            }

            return View(new ProductCreateVm());
        }

        [HttpPost]
        public async Task<IActionResult> Create(ProductCreateVm model)
        {
            if (!ModelState.IsValid)
            {
                var httpClient = _httpClientFactory.CreateClient("ApiClient");

                var colorResponse = await httpClient.GetAsync("http://localhost:5202/api/color");
                if (colorResponse.IsSuccessStatusCode)
                {
                    var colorContent = await colorResponse.Content.ReadAsStringAsync();
                    ViewBag.Colors = JsonSerializer.Deserialize<List<ColorVm>>(colorContent, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                }

                var categoryResponse = await httpClient.GetAsync("http://localhost:5202/api/category");
                if (categoryResponse.IsSuccessStatusCode)
                {
                    var categoryContent = await categoryResponse.Content.ReadAsStringAsync();
                    ViewBag.Categories = JsonSerializer.Deserialize<List<CategoryReturnDto>>(categoryContent, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                }

                return View(model);
            }

            try
            {
                var httpClient = _httpClientFactory.CreateClient("ApiClient");
                var jsonContent = JsonSerializer.Serialize(model);
                var contentString = new StringContent(jsonContent, System.Text.Encoding.UTF8, "application/json");

                var response = await httpClient.PostAsync("http://localhost:5202/api/product", contentString);

                if (response.IsSuccessStatusCode)
                {
                    TempData["SuccessMessage"] = "Product created successfully!";
                    return RedirectToAction(nameof(Index));
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    TempData["ErrorMessage"] = $"Failed to create product. Status: {response.StatusCode}, Details: {errorContent}";
                }
            }
            catch (Exception ex)
            {
                TempData["ErrorMessage"] = $"An error occurred: {ex.Message}";
            }

            return View(model);
        }
    }
}
